<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0c0a09">

    <!-- SwipeRefreshLayout wrapping WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0c0a09" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Loading progress bar (top edge) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:progressTint="#f59e0b"
        android:progressBackgroundTint="#1c1917"
        android:max="100"
        android:visibility="gone" />

    <!-- Offline error screen -->
    <LinearLayout
        android:id="@+id/offlineLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#0c0a09"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Internet Connection"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please check your connection and try again."
            android:textColor="#78716c"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="Try Again"
            android:textColor="#0c0a09"
            android:backgroundTint="#f59e0b"
            android:textStyle="bold"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Splash screen (shown on top while loading) -->
    <LinearLayout
        android:id="@+id/splashLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0c0a09"
        android:visibility="visible">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/splash_logo"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forjit AI"
            android:textColor="#f59e0b"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Free Indian AI Tools"
            android:textColor="#78716c"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
